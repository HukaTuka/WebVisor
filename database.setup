        CREATE TABLE dbo.Clients (
                                     ID   int          IDENTITY CONSTRAINT PK_Clients PRIMARY KEY,
                                     Name varchar(150) NOT NULL CONSTRAINT UQ_Clients_Name UNIQUE
        );
        GO

        CREATE TABLE dbo.Profiles (
                                      ID              INT PRIMARY KEY IDENTITY(1,1),
                                      Name            VARCHAR(100) NOT NULL,
                                      DefaultRotation INT          NOT NULL DEFAULT 0,
                                      SplitOnBarcode  bit          NOT NULL DEFAULT ((0)),
                                      ClientID        INT          NOT NULL DEFAULT 0,
                                      FOREIGN KEY (ClientID) REFERENCES Clients(ID)
        );

        CREATE TABLE dbo.UserProfiles (
                                          UserID    INT NOT NULL,
                                          ProfileID INT NOT NULL,
                                          PRIMARY KEY (UserID, ProfileID),
                                          FOREIGN KEY (UserID)    REFERENCES Users(ID),
                                          FOREIGN KEY (ProfileID) REFERENCES Profiles(ID)
        );
        GO

-- Archives uses ID (not ArchiveID) from the start to match what the Java DAOs expect
        CREATE TABLE dbo.Archives (
                                      ID        int          IDENTITY PRIMARY KEY,
                                      Name      varchar(150) NOT NULL,
                                      ClientID  int          NOT NULL,
                                      CreatedAt datetime2    NOT NULL CONSTRAINT DF_Archives_CreatedAt DEFAULT SYSDATETIME()
        );
        GO

        CREATE INDEX IX_Archives_ClientID ON dbo.Archives (ClientID);
        GO

        CREATE TABLE dbo.Boxes (
                                   BoxID     varchar(50) NOT NULL CONSTRAINT PK_Boxes PRIMARY KEY,
                                   ClientID  int         NOT NULL CONSTRAINT FK_Boxes_Clients  REFERENCES dbo.Clients,
                                   ArchiveID int         NULL     CONSTRAINT FK_Boxes_Archives REFERENCES dbo.Archives(ID),
                                   CreatedAt datetime2   NOT NULL CONSTRAINT DF_Boxes_CreatedAt DEFAULT SYSDATETIME()
        );
        GO

        CREATE TABLE dbo.Documents (
                                       ID             int        IDENTITY CONSTRAINT PK_Documents PRIMARY KEY,
                                       BoxID          varchar(50) NOT NULL CONSTRAINT FK_Documents_Boxes REFERENCES dbo.Boxes ON DELETE CASCADE,
                                       DocumentNumber int         NOT NULL CONSTRAINT CK_Documents_DocumentNumber_Positive CHECK ([DocumentNumber] > 0),
                                       Status         varchar(30) NOT NULL CONSTRAINT DF_Documents_Status DEFAULT 'IN_PROGRESS',
                                       RejectionNote  varchar(500) NULL,
                                       CreatedAt      datetime2   NOT NULL CONSTRAINT DF_Documents_CreatedAt DEFAULT SYSDATETIME(),
                                       CONSTRAINT UQ_Documents_Box_DocumentNumber UNIQUE (BoxID, DocumentNumber)
        );
        GO

        CREATE INDEX IX_Documents_BoxID ON dbo.Documents (BoxID);
        GO

        CREATE TABLE dbo.Files (
                                   ID              int           IDENTITY CONSTRAINT PK_Files PRIMARY KEY,
                                   BoxID           varchar(50)   NOT NULL CONSTRAINT FK_Files_Boxes      REFERENCES dbo.Boxes      ON DELETE CASCADE,
                                   DocumentID      int           NULL     CONSTRAINT FK_Files_Documents  REFERENCES dbo.Documents,
                                   PageNumber      int           NOT NULL,
                                   IsBarcode       bit           NOT NULL,
                                   RotationDegrees int           NOT NULL,
                                   ImageData       varbinary(max) NOT NULL,
                                   CreatedAt       datetime2     NOT NULL CONSTRAINT DF_Files_CreatedAt DEFAULT SYSDATETIME()
        );
        GO

        CREATE INDEX IX_Files_BoxID      ON dbo.Files (BoxID);
        CREATE INDEX IX_Files_DocumentID ON dbo.Files (DocumentID);
        GO

        CREATE TABLE dbo.MetadataFields (
                                            ID        INT          PRIMARY KEY IDENTITY(1,1),
                                            Name      VARCHAR(150) NOT NULL,
                                            FieldType VARCHAR(20)  NOT NULL DEFAULT 'TEXT'
        );
        GO

        CREATE TABLE dbo.BoxMetadata (
                                         ID      INT         PRIMARY KEY IDENTITY(1,1),
                                         BoxID   VARCHAR(50) NOT NULL,
                                         FieldID INT         NOT NULL,
                                         Value   VARCHAR(500) NULL,
                                         CONSTRAINT FK_BoxMetadata_Boxes  FOREIGN KEY (BoxID)    REFERENCES dbo.Boxes(BoxID)          ON DELETE CASCADE,
                                         CONSTRAINT FK_BoxMetadata_Fields FOREIGN KEY (FieldID)  REFERENCES dbo.MetadataFields(ID)    ON DELETE CASCADE,
                                         CONSTRAINT UQ_BoxMetadata        UNIQUE (BoxID, FieldID)
        );
        GO

        CREATE INDEX IX_BoxMetadata_BoxID ON dbo.BoxMetadata (BoxID);
        GO
