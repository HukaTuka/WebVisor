      USE master;
        GO
        IF EXISTS(SELECT * FROM sys.databases WHERE name = 'felnie01_WebVisor')
            BEGIN
                DROP DATABASE felnie01_WebVisor;
            END

        CREATE DATABASE felnie01_WebVisor;
        GO
        USE felnie01_WebVisor;
        GO

        CREATE TABLE felnie01_WebVisor.dbo.Users (
                                                     ID        int           PRIMARY KEY NOT NULL,
                                                     Username  varchar(100),
                                                     Password  varchar(255),
                                                     Role      varchar(20),
                                                     Timestamp DATETIME2     NULL,
                                                     IsSeeded  bit           DEFAULT ((0)) NOT NULL
        );

        CREATE TABLE felnie01_WebVisor.dbo.AuditLog (
                                                        ID        INT          PRIMARY KEY IDENTITY(1,1),
                                                        Timestamp DATETIME2    NOT NULL DEFAULT SYSDATETIME(),
                                                        Username  VARCHAR(100) NOT NULL,
                                                        Action    VARCHAR(100) NOT NULL,
                                                        Details   VARCHAR(500) NOT NULL
        );

