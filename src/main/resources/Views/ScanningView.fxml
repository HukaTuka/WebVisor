<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="880.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.sea.webvisor.GUI.Controllers.ScanningController">
    <children>
        <VBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="scanning-toolbar">
                <padding>
                    <Insets bottom="10.0" left="16.0" right="16.0" top="10.0" />
                </padding>
                <children>
                    <Label minWidth="190.0" prefWidth="190.0" maxWidth="190.0" styleClass="title-label" text="Scanning Session" />
                    <HBox prefWidth="18.0" />
                    <Button fx:id="btnStart" minWidth="130.0" prefWidth="130.0" maxWidth="130.0" onAction="#onStartScanning" styleClass="primary-button" text="▶  Start Scanning" />
                    <Button fx:id="btnStop" minWidth="80.0" prefWidth="80.0" maxWidth="80.0" disable="true" onAction="#onStopScanning" styleClass="danger-button" text="■  Stop" />
                    <Label styleClass="separator-label" text="|" />
                    <Label fx:id="lblTotalScans" minWidth="110.0" styleClass="page-info-label" text="Total Scans: 0" />
                    <Label styleClass="separator-label" text="|" />
                    <Button fx:id="btnRotateLeft" minWidth="80.0" prefWidth="80.0" maxWidth="80.0" disable="true" onAction="#onRotateLeft" styleClass="secondary-button" text="↺ Left" />
                    <Button fx:id="btnRotateRight" minWidth="80.0" prefWidth="80.0" maxWidth="80.0" disable="true" onAction="#onRotateRight" styleClass="secondary-button" text="↻ Right" />
                    <Label styleClass="separator-label" text="|" />
                    <Button fx:id="btnDelete" minWidth="90.0" prefWidth="90.0" maxWidth="90.0" disable="true" onAction="#onDelete" styleClass="secondary-button" text="🗑 Delete" />
                    <Label styleClass="separator-label" text="|" />
                    <Button fx:id="btnPrev" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" disable="true" onAction="#onPrev" styleClass="secondary-button" text="◀" />
                    <Label fx:id="lblPageInfo" minWidth="90.0" styleClass="page-info-label" text="Page 0 / 0" />
                    <Button fx:id="btnNext" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" disable="true" onAction="#onNext" styleClass="secondary-button" text="▶" />
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="status-bar">
                <padding>
                    <Insets bottom="6.0" left="16.0" right="16.0" top="6.0" />
                </padding>
                <children>
                    <Label text="Box ID:" />
                    <TextField fx:id="txtBoxId" prefWidth="160.0" styleClass="input-field" />
                    <Button onAction="#onCreateBox" styleClass="secondary-button" text="Create Box" />
                    <Label styleClass="separator-label" text="|" />
                    <Label fx:id="lblCurrentBox" styleClass="status-label" text="Current box: none" />
                </children>
            </HBox>

            <HBox spacing="0.0" VBox.vgrow="ALWAYS">
                <children>
                    <VBox minWidth="320.0" prefWidth="320.0" maxWidth="320.0" spacing="8.0" styleClass="page-list-panel">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <Button fx:id="btnBack" disable="true" onAction="#onBack" styleClass="secondary-button" text="← Back" />
                                    <Label fx:id="lblExplorerPath" styleClass="panel-header-label" text="Boxes" />
                                </children>
                            </HBox>
                            <ListView fx:id="lstExplorer" styleClass="pages-list" VBox.vgrow="ALWAYS" />
                        </children>
                    </VBox>

                    <StackPane styleClass="image-viewer-panel" HBox.hgrow="ALWAYS">
                        <children>
                            <ImageView fx:id="imgPage" fitHeight="500.0" fitWidth="1100.0" preserveRatio="true" smooth="true" />
                        </children>
                    </StackPane>
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" styleClass="status-bar">
                <padding>
                    <Insets bottom="6.0" left="16.0" right="16.0" top="6.0" />
                </padding>
                <children>
                    <Label fx:id="lblStatus" styleClass="status-label" text="" />
                </children>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
