<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.sea.webvisor.GUI.Controllers.MetadataDialogController"
            prefWidth="540.0" prefHeight="460.0"
            styleClass="root-pane">

    <top>
        <VBox styleClass="scanning-toolbar">
            <padding>
                <Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/>
            </padding>
            <children>
                <Label fx:id="lblBoxTitle" styleClass="title-label" text="Box Metadata"/>
                <Label text="Fill in the metadata values for this box. Changes are saved when you click Save."
                       styleClass="status-info" wrapText="true"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" pannable="false" styleClass="content-area">
            <padding>
                <Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/>
            </padding>
            <content>
                <VBox spacing="12.0">
                    <children>
                        <Label fx:id="lblNoFields"
                               text="No metadata fields have been defined. An administrator can add fields under Manage Metadata Fields."
                               styleClass="empty-state-label"
                               wrapText="true"
                               visible="false"
                               managed="false"/>
                        <VBox fx:id="fieldsContainer" spacing="0.0"/>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <VBox styleClass="status-bar">
            <padding>
                <Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/>
            </padding>
            <children>
                <Label fx:id="lblStatus" styleClass="status-label" text=""/>
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button text="Save" onAction="#onSave"  styleClass="primary-button"   prefWidth="100.0"/>
                        <Button text="Close" onAction="#onClose" styleClass="secondary-button" prefWidth="100.0"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>

</BorderPane>