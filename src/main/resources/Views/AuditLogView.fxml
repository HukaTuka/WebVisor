<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.control.Button?>
        <?import javafx.scene.control.ComboBox?>
        <?import javafx.scene.control.Label?>
        <?import javafx.scene.control.TableColumn?>
        <?import javafx.scene.control.TableView?>
        <?import javafx.scene.control.TextField?>
        <?import javafx.scene.layout.AnchorPane?>
        <?import javafx.scene.layout.HBox?>
        <?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" styleClass="root-pane"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.sea.webvisor.GUI.Controllers.AuditLogController">
    <children>
        <VBox spacing="12.0"
              AnchorPane.topAnchor="24.0"
              AnchorPane.bottomAnchor="24.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0">
            <children>

                <!-- Header -->
                <Label styleClass="page-title" text="Audit Log" />

                <!-- Filter bar -->
                <HBox spacing="10.0" styleClass="filter-bar">
                    <children>
                        <TextField fx:id="txtFilterUsername"
                                   promptText="Filter by username..."
                                   prefWidth="220.0"
                                   styleClass="filter-field"
                                   onKeyReleased="#onFilterChanged" />

                        <ComboBox fx:id="cmbFilterAction"
                                  promptText="All actions"
                                  prefWidth="180.0"
                                  styleClass="filter-field"
                                  onAction="#onFilterChanged" />

                        <Button text="Clear Filters"
                                styleClass="sidebar-nav-button"
                                onAction="#onClearFilters" />

                        <HBox HBox.hgrow="ALWAYS" />

                        <Label fx:id="lblEntryCount"
                               styleClass="status-info"
                               text="0 entries" />
                    </children>
                </HBox>

                <!-- Audit table -->
                <TableView fx:id="tblAuditLog"
                           styleClass="content-area"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTimestamp"
                                     text="Timestamp"
                                     prefWidth="170.0"
                                     minWidth="140.0" />

                        <TableColumn fx:id="colUsername"
                                     text="Username"
                                     prefWidth="140.0"
                                     minWidth="100.0" />

                        <TableColumn fx:id="colAction"
                                     text="Action"
                                     prefWidth="180.0"
                                     minWidth="120.0" />

                        <TableColumn fx:id="colDetails"
                                     text="Details"
                                     prefWidth="560.0"
                                     minWidth="200.0" />
                    </columns>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>