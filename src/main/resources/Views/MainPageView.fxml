<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.sea.webvisor.GUI.Controllers.MainPageController"
            prefHeight="700.0" prefWidth="1100.0"
            styleClass="root-pane">
    <children>
        <HBox AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
            <children>
                <VBox spacing="8.0" prefWidth="220.0" styleClass="sidebar">
                    <children>
                        <Label text="WebVisor" styleClass="sidebar-title"/>
                        <VBox fx:id="userMenu" spacing="8.0">
                            <children>
                                <Button text="Home"     onAction="#onOpenHome"     styleClass="sidebar-nav-button"/>
                                <Button text="Scanning" onAction="#onOpenScanning" styleClass="sidebar-nav-button"/>
                            </children>
                        </VBox>
                        <VBox fx:id="adminMenu" spacing="8.0">
                            <children>
                                <Button text="Manage Users" onAction="#onOpenAdminUsers" styleClass="sidebar-nav-button"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Main content area -->
                <StackPane fx:id="contentArea" styleClass="content-area" HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>
    </children>
</AnchorPane>
