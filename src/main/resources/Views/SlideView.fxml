<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.sea.webvisor.GUI.Controllers.SlideViewController"
            fx:id="rootPane"
            styleClass="root-pane"
            prefWidth="1100.0" prefHeight="800.0">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER" spacing="20.0" styleClass="scanning-toolbar">
            <padding><Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/></padding>
            <Button text="✕  Close" onAction="#onClose" styleClass="danger-button" focusTraversable="false"/>
            <Label fx:id="lblPageInfo" styleClass="page-info-label" text=""/>
            <Label fx:id="lblBarcodeWarning" text="⚠ BARCODE PAGE"
                   styleClass="status-error" visible="false" managed="false"/>
        </HBox>
    </top>

    <!-- Image area -->
    <!-- Image area -->
    <center>
        <StackPane styleClass="image-viewer-panel">
            <ImageView fx:id="imgSlide"
                       fitWidth="1060.0" fitHeight="700.0"
                       preserveRatio="true" smooth="true"/>
        </StackPane>
    </center>

    <!-- Bottom nav -->
    <bottom>
        <HBox alignment="CENTER" spacing="30.0" styleClass="status-bar">
            <padding><Insets top="8.0" right="16.0" bottom="8.0" left="16.0"/></padding>
            <Button text="◀  Previous" onAction="#onPrev" styleClass="secondary-button" focusTraversable="false"/>
            <Label text="← → arrow keys also work" styleClass="status-info"/>
            <Button text="Next  ▶" onAction="#onNext" styleClass="secondary-button" focusTraversable="false"/>
        </HBox>
    </bottom>

</BorderPane>